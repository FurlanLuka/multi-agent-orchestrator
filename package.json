{
  "name": "multi-agent-orchestrator",
  "version": "1.0.0",
  "description": "Coordinates multiple Claude Code agents working on different projects simultaneously",
  "main": "dist/index.js",
  "scripts": {
    "dev": "npm run build:web && ts-node src/index.ts",
    "build": "tsc",
    "build:web": "cd web && npm run build",
    "start": "npm run build && npm run build:web && node dist/index.js"
  },
  "keywords": ["claude", "agent", "orchestrator"],
  "license": "MIT",
  "dependencies": {
    "chokidar": "^3.5.3",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "socket.io": "^4.7.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.2"
  }
}
