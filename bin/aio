#!/usr/bin/env bash
# AIO Orchestrator CLI
# Run this from anywhere to start the orchestrator

set -e

# Find the script directory (resolve symlinks)
SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "$0" 2>/dev/null || echo "$0")")" && pwd)"
ROOT_DIR="$(dirname "$SCRIPT_DIR")"

cd "$ROOT_DIR"

# Default port
PORT="${AIO_PORT:-3456}"

echo "🚀 Starting AIO Orchestrator on port $PORT..."

# Detect platform
ARCH=$(uname -m)
OS=$(uname -s | tr '[:upper:]' '[:lower:]')

# Map arch names
if [ "$ARCH" = "arm64" ]; then
  ARCH="aarch64"
elif [ "$ARCH" = "x86_64" ]; then
  ARCH="x86_64"
fi

# Map OS names
if [ "$OS" = "darwin" ]; then
  PLATFORM="${ARCH}-apple-darwin"
elif [ "$OS" = "linux" ]; then
  PLATFORM="${ARCH}-unknown-linux-gnu"
else
  PLATFORM=""
fi

# Look for pkg binary
BINARY="orchestrator-tauri/binaries/aio-orchestrator-backend-${PLATFORM}"

if [ -x "$BINARY" ]; then
  echo "📦 Using compiled binary: $BINARY"

  # Open browser after a short delay
  (sleep 2 && open "http://localhost:$PORT" 2>/dev/null || xdg-open "http://localhost:$PORT" 2>/dev/null || echo "Open http://localhost:$PORT in your browser") &

  # Run the binary
  PORT="$PORT" "$BINARY"
else
  echo "📦 No compiled binary found, using Node.js..."

  # Check if backend is built
  if [ ! -f "orchestrator-backend/dist/index.js" ]; then
    echo "📦 Building backend..."
    npm run build:backend
  fi

  # Check if frontend is built
  if [ ! -d "orchestrator-web/dist" ]; then
    echo "📦 Building frontend..."
    npm run build:web
  fi

  # Open browser after a short delay
  (sleep 2 && open "http://localhost:$PORT" 2>/dev/null || xdg-open "http://localhost:$PORT" 2>/dev/null || echo "Open http://localhost:$PORT in your browser") &

  # Run with Node
  PORT="$PORT" node orchestrator-backend/dist/index.js
fi
