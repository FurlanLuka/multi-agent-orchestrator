{
  "projects": {
    "speak-api": {
      "path": "~/Documents/speak-api",
      "devServer": {
        "command": "npm run start",
        "readyPattern": "ready|listening|started|compiled",
        "env": {}
      },
      "buildCommand": "npm run build",
      "hasE2E": false
    },
    "speak-partner": {
      "path": "~/Documents/speak-partner",
      "devServer": {
        "command": "npm run dev",
        "readyPattern": "ready|listening|started|compiled",
        "env": {}
      },
      "buildCommand": "npm run build",
      "hasE2E": false
    }
  },
  "defaults": {
    "approvalTimeout": 300000,
    "maxRestarts": 3,
    "debugEscalationTime": 120000
  }
}