{
    "name": "nestjs-backend",
    "version": "0.0.1",
    "private": true,
    "scripts": {
        "build": "prettier --write \"src/**/*.ts\" \"prisma/**/*.ts\" \"prisma.config.ts\" && nest build",
        "start": "nest start",
        "start:dev": "nest start --watch",
        "start:debug": "nest start --debug --watch",
        "start:prod": "node dist/main",
        "typecheck": "tsc --noEmit",
        "format": "prettier --write \"src/**/*.ts\" \"prisma/**/*.ts\" \"prisma.config.ts\"",
        "format:check": "prettier --check \"src/**/*.ts\" \"prisma/**/*.ts\" \"prisma.config.ts\"",
        "db:generate": "prisma generate",
        "db:migrate": "prisma migrate dev",
        "db:migrate:prod": "prisma migrate deploy",
        "db:push": "prisma db push",
        "db:seed": "prisma db seed",
        "db:studio": "prisma studio"
    },
    "dependencies": {
        "@nestjs/common": "^11.1.12",
        "@nestjs/config": "^4.0.2",
        "@nestjs/core": "^11.1.12",
        "@nestjs/platform-express": "^11.1.12",
        "@prisma/client": "^7.3.0",
        "class-transformer": "^0.5.1",
        "class-validator": "^0.14.3",
        "reflect-metadata": "^0.2.2",
        "rxjs": "^7.8.2"
    },
    "devDependencies": {
        "@nestjs/cli": "^11.0.16",
        "@types/express": "^5.0.6",
        "@types/node": "^25.1.0",
        "prettier": "^3.8.1",
        "prisma": "^7.3.0",
        "ts-node": "^10.9.2",
        "typescript": "^5.9.3"
    },
    "prisma": {
        "seed": "ts-node prisma/seed.ts"
    }
}
