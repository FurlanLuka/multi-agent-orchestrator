{
    "name": "vite-frontend",
    "private": true,
    "version": "0.0.0",
    "type": "module",
    "scripts": {
        "dev": "vite",
        "build": "prettier --write \"src/**/*.{ts,tsx}\" && tsc --noEmit && vite build",
        "preview": "vite preview",
        "typecheck": "tsc --noEmit",
        "format": "prettier --write \"src/**/*.{ts,tsx}\"",
        "format:check": "prettier --check \"src/**/*.{ts,tsx}\""
    },
    "dependencies": {
        "@mantine/core": "^8.3.13",
        "@mantine/hooks": "^8.3.13",
        "@tanstack/react-query": "^5.90.20",
        "axios": "^1.13.4",
        "react": "^19.2.4",
        "react-dom": "^19.2.4",
        "react-router-dom": "^7.13.0"
    },
    "devDependencies": {
        "@types/react": "^19.2.10",
        "@types/react-dom": "^19.2.3",
        "@vitejs/plugin-react": "^5.1.2",
        "prettier": "^3.8.1",
        "typescript": "^5.9.3",
        "vite": "^7.3.1"
    }
}
