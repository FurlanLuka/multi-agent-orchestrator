{
  "name": "@aio/backend",
  "version": "1.0.0",
  "description": "AIO Orchestrator backend server",
  "main": "dist/index.js",
  "scripts": {
    "dev": "NODE_ENV=development ts-node src/index.ts",
    "build": "tsc",
    "build:pkg": "pkg dist/index.js --targets node18-macos-arm64 -o ../orchestrator-tauri/binaries/aio-orchestrator-backend-aarch64-apple-darwin",
    "build:pkg-macos-arm64": "pkg dist/index.js --targets node18-macos-arm64 --output ../orchestrator-tauri/binaries/aio-orchestrator-backend-aarch64-apple-darwin",
    "build:pkg-macos-x64": "pkg dist/index.js --targets node18-macos-x64 --output ../orchestrator-tauri/binaries/aio-orchestrator-backend-x86_64-apple-darwin",
    "build:pkg-linux-x64": "pkg dist/index.js --targets node18-linux-x64 --output ../orchestrator-tauri/binaries/aio-orchestrator-backend-x86_64-unknown-linux-gnu",
    "build:pkg-windows-x64": "pkg dist/index.js --targets node18-win-x64 --output ../orchestrator-tauri/binaries/aio-orchestrator-backend-x86_64-pc-windows-msvc.exe",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@aio/types": "*",
    "chokidar": "^3.5.3",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "socket.io": "^4.7.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.0",
    "pkg": "^5.8.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.2"
  },
  "pkg": {
    "scripts": "dist/**/*.js",
    "assets": [
      "setup/**/*"
    ],
    "targets": [
      "node18-macos-arm64",
      "node18-macos-x64",
      "node18-linux-x64",
      "node18-win-x64"
    ],
    "outputPath": "../orchestrator-tauri/binaries"
  }
}
