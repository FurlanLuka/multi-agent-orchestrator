{
  "name": "@orchy/backend",
  "version": "1.0.0",
  "description": "Orchy backend server",
  "main": "dist/index.js",
  "bin": "dist/index.js",
  "scripts": {
    "dev": "NODE_ENV=development ts-node src/index.ts",
    "build": "tsc",
    "obfuscate": "javascript-obfuscator dist --output dist --config obfuscator.config.json",
    "build:pkg-all": "pkg . --targets node18-macos-arm64,node18-macos-x64,node18-linux-x64,node18-win-x64 --out-path ../dist",
    "clean": "rm -rf dist web-dist"
  },
  "dependencies": {
    "@orchy/types": "*",
    "archiver": "^7.0.1",
    "chokidar": "^3.5.3",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "socket.io": "^4.7.2"
  },
  "devDependencies": {
    "@types/archiver": "^7.0.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.0",
    "javascript-obfuscator": "^5.1.0",
    "pkg": "^5.8.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.2"
  },
  "pkg": {
    "scripts": "dist/**/*.js",
    "assets": [
      "web-dist/**/*",
      "setup/**/*"
    ],
    "targets": [
      "node18-macos-arm64",
      "node18-macos-x64",
      "node18-linux-x64",
      "node18-win-x64"
    ],
    "outputPath": "../dist"
  }
}
